---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import avisData from '../data/avis.json';
import { WA_PATH } from '../lib/ui.js';
import { breadcrumb } from '../lib/jsonld.js';

const url = new URL('/avis', site.url).href;
const waLink = `https://wa.me/${site.whatsapp}`;
const jsonLd = [breadcrumb([{ name: 'Accueil', url: site.url }, { name: 'Avis clients', url }])];
const stars = [0, 1, 2, 3, 4];
---
<Layout
  title="Avis clients Ultimauto — 4,9/5 sur Google"
  description="Les avis clients d'Ultimauto à Cholet : 4,9/5 sur 450 avis Google. Décalaminage, nettoyage FAP, reprogrammation, AdBlue — retours réels et vérifiés."
  jsonLd={jsonLd}
  ogImage="/img/photo-1.jpg"
  preloadImage="/img/atelier.jpg"
>
  <section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(180deg, rgba(25,106,213,0.84) 0%, rgba(21,101,192,0.94) 100%), url('/img/atelier.jpg');">
    <div class="mx-auto max-w-[1180px] px-6 py-14 text-white md:py-20">
      <nav aria-label="Fil d'Ariane" class="text-sm text-white/75"><a href="/" class="hover:text-white">Accueil</a> <span class="px-1.5">/</span> <span class="text-white">Avis clients</span></nav>
      <h1 class="mt-4 text-4xl font-extrabold text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] md:text-5xl">Avis clients</h1>
      <div class="mt-5 inline-flex items-center gap-3 rounded-full bg-white/15 px-5 py-2.5 backdrop-blur">
        <span class="flex text-accent" aria-hidden="true">{stars.map(() => <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="m12 2 3 6.3 6.9.9-5 4.8 1.2 6.8L12 17.8 5.9 20.8 7.1 14l-5-4.8 6.9-.9z" /></svg>)}</span>
        <span class="font-display text-xl font-extrabold text-white">{avisData.rating}/5</span>
        <span class="text-sm text-white/85">· {avisData.count} avis Google</span>
      </div>
      <p class="mt-4 max-w-2xl text-white/90">Voici une sélection des retours laissés par nos clients sur Google. Merci à eux pour leur confiance — c'est notre meilleure récompense.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="mx-auto max-w-[1180px] px-6">
      <div class="columns-1 gap-6 md:columns-2 lg:columns-3 [&>*]:mb-6">
        {avisData.items.map((a) => (
          <figure class="break-inside-avoid rounded-3xl border border-line bg-white p-6 shadow-[var(--shadow-soft)]">
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5 text-accent" aria-hidden="true">{stars.map(() => <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="m12 2 3 6.3 6.9.9-5 4.8 1.2 6.8L12 17.8 5.9 20.8 7.1 14l-5-4.8 6.9-.9z" /></svg>)}</div>
              <span class="text-xs font-bold text-ink-500">Google</span>
            </div>
            <blockquote class="mt-3 text-ink-700">«&#160;{a.texte}&#160;»</blockquote>
            <figcaption class="mt-4 flex items-center justify-between gap-2 border-t border-line pt-3">
              <span class="font-bold">{a.auteur}</span>
              {a.meta && <span class="text-xs text-ink-500">{a.meta}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href={avisData.url} target="_blank" rel="noopener" class="btn-primary">Voir et laisser un avis sur Google</a>
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-br from-deep to-brand py-16 text-white">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">Rejoignez nos clients satisfaits</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">Diagnostic et devis gratuits. Prenez rendez-vous ou écrivez-nous sur WhatsApp.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/prise-de-rendez-vous" class="rounded-full bg-accent px-7 py-3.5 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Prendre rendez-vous</a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white hover:bg-white/10"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d={WA_PATH} /></svg>Devis WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>
