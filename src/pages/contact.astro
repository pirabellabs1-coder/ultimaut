---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import services from '../data/services.json';
import { WA_PATH, socialLinks } from '../lib/ui.js';
import { breadcrumb } from '../lib/jsonld.js';
import MapBlock from '../components/MapBlock.astro';

const waLink = `https://wa.me/${site.whatsapp}`;
const socials = socialLinks(site);
const url = new URL('/contact', site.url).href;
const jsonLd = [breadcrumb([{ name: 'Accueil', url: site.url }, { name: 'Contact', url }])];
---
<Layout
  title="Contact — Ultimauto Cholet | Devis gratuit"
  description="Contactez Ultimauto à Cholet : téléphone, WhatsApp ou formulaire. Devis gratuit — décalaminage, FAP, reprogrammation, AdBlue. Service mobile."
  jsonLd={jsonLd}
  ogImage="/img/atelier.jpg"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(180deg, rgba(25,106,213,0.82) 0%, rgba(21,101,192,0.93) 100%), url('/img/atelier.jpg');">
    <div class="mx-auto max-w-[1180px] px-6 py-14 text-white md:py-20">
      <nav aria-label="Fil d'Ariane" class="text-sm text-white/75"><a href="/" class="hover:text-white">Accueil</a> <span class="px-1.5">/</span> <span class="text-white">Contact</span></nav>
      <h1 class="mt-4 text-4xl font-extrabold text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] md:text-5xl">Contactez Ultimauto</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/90">Une question, un doute, un devis&#8239;? Écrivez-nous ou appelez-nous. Le plus rapide reste WhatsApp&#160;: vous pouvez même nous envoyer une photo ou une vidéo de votre problème.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="mx-auto grid max-w-[1180px] gap-10 px-6 lg:grid-cols-[1.2fr_1fr]">
      <!-- Formulaire -->
      <div class="rounded-3xl border border-line bg-cloud p-7 md:p-8">
        <h2 class="text-2xl font-bold">Envoyez-nous un message</h2>
        <p class="mt-2 text-sm text-ink-700">Réponse sous 24 h ouvrées. Les champs marqués d'un * sont obligatoires.</p>
        <form id="contact-form" class="mt-6 space-y-4" novalidate>
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block"><span class="text-sm font-semibold">Nom *</span><input required name="nom" type="text" autocomplete="name" class="mt-1.5 w-full rounded-xl border border-line bg-white px-4 py-2.5 outline-none focus:border-brand" /></label>
            <label class="block"><span class="text-sm font-semibold">Téléphone *</span><input required name="telephone" type="tel" autocomplete="tel" class="mt-1.5 w-full rounded-xl border border-line bg-white px-4 py-2.5 outline-none focus:border-brand" /></label>
          </div>
          <label class="block"><span class="text-sm font-semibold">E-mail</span><input name="email" type="email" autocomplete="email" class="mt-1.5 w-full rounded-xl border border-line bg-white px-4 py-2.5 outline-none focus:border-brand" /></label>
          <label class="block"><span class="text-sm font-semibold">Message *</span><textarea required name="message" rows="5" class="mt-1.5 w-full rounded-xl border border-line bg-white px-4 py-2.5 outline-none focus:border-brand"></textarea></label>
          <button type="submit" class="btn-primary w-full">Envoyer le message</button>
          <p data-form-status role="status" aria-live="polite" class="hidden text-sm"></p>
          <p class="text-xs text-ink-500">En envoyant ce formulaire, vous acceptez que vos données soient utilisées pour traiter votre demande (voir notre <a href="/politique-de-confidentialite" class="underline">politique de confidentialité</a>).</p>
        </form>
        <script>
          const form = document.getElementById('contact-form');
          if (form) {
            const status = form.querySelector('[data-form-status]');
            const btn = form.querySelector('button[type="submit"]');
            const setStatus = (msg, cls) => { status.textContent = msg; status.className = 'text-sm font-semibold ' + cls; };
            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              if (!form.reportValidity()) return;
              const data = Object.fromEntries(new FormData(form).entries());
              btn.disabled = true;
              setStatus('Envoi en cours…', 'text-ink-600');
              try {
                const res = await fetch('/api/contact', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify(data),
                });
                if (res.ok) {
                  form.reset();
                  setStatus('✅ Message envoyé&#8239;! Nous vous répondons sous 24 h ouvrées.', 'text-accent-700');
                } else {
                  setStatus('❌ Une erreur est survenue. Réessayez ou appelez-nous au 06 52 19 36 05.', 'text-red-600');
                }
              } catch {
                setStatus('❌ Connexion impossible. Réessayez ou appelez-nous au 06 52 19 36 05.', 'text-red-600');
              } finally {
                btn.disabled = false;
              }
            });
          }
        </script>
      </div>

      <!-- Coordonnées -->
      <div class="space-y-5">
        <div class="rounded-3xl border border-line p-7">
          <h2 class="text-xl font-bold">Nos coordonnées</h2>
          <ul class="mt-5 space-y-4 text-sm">
            <li class="flex items-center gap-3"><span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.1 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.4-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z"/></svg></span><a href={`tel:${site.phone}`} class="text-base font-bold text-ink hover:text-brand">{site.phoneDisplay}</a></li>
            <li class="flex items-center gap-3"><span class="grid h-10 w-10 place-items-center rounded-xl bg-whatsapp/10 text-whatsapp-600"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d={WA_PATH} /></svg></span><a href={waLink} target="_blank" rel="noopener" class="font-semibold text-ink hover:text-brand">Écrire sur WhatsApp</a></li>
            <li class="flex items-center gap-3"><span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="m4 6 8 6 8-6"/></svg></span><a href={`mailto:${site.email}`} class="font-semibold text-ink hover:text-brand">{site.email}</a></li>
            <li class="flex items-center gap-3"><span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-5.5-7-11a7 7 0 0 1 14 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span><span class="font-semibold text-ink">{site.address.street}, {site.address.postalCode} {site.address.city}</span></li>
          </ul>
          <div class="mt-5 flex items-center gap-3">
            {socials.map((s) => <a href={s.href} target="_blank" rel="noopener" aria-label={s.name}><img src={s.img} alt="" width="30" height="30" class="h-[30px] w-[30px]" /></a>)}
          </div>
        </div>
        <div class="rounded-3xl border border-line p-7">
          <h2 class="text-xl font-bold">Horaires</h2>
          <ul class="mt-4 space-y-2 text-sm">
            {site.openingHoursDisplay.map((h) => (
              <li class="flex justify-between border-b border-line pb-2 last:border-0"><span class="text-ink-700">{h.label}</span><span class="font-semibold">{h.hours}</span></li>
            ))}
          </ul>
        </div>
        <a href="/prise-de-rendez-vous" class="btn-primary w-full">Prendre rendez-vous en ligne</a>
      </div>
    </div>
  </section>

  <!-- Carte -->
  <MapBlock bg="bg-cloud" />
</Layout>
