---
import Layout from '../../layouts/Layout.astro';
import services from '../../data/services.json';
import site from '../../data/site.json';
import tarifs from '../../data/tarifs.json';
import { ICONS, WA_PATH, SERVICE_PHOTO } from '../../lib/ui.js';
import EcoValues from '../../components/EcoValues.astro';
import Gallery from '../../components/Gallery.astro';
import { villeSlug } from '../../lib/slug.js';
import { getCollection } from 'astro:content';
import { villesPourService } from '../../lib/pages.js';
import { service as serviceLd, faqPage, breadcrumb } from '../../lib/jsonld.js';

export function getStaticPaths() {
  return services.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const waLink = `https://wa.me/${site.whatsapp}`;
const url = new URL(`/${service.slug}`, site.url).href;
const cat = tarifs.categories.find((c) => c.service === service.slug);
const autres = services.filter((s) => s.slug !== service.slug).slice(0, 6);
const villesMaillage = service.local ? villesPourService(service.slug).slice(0, 12) : [];
const relatedPosts = (await getCollection('blog')).filter((p) => p.data.service === service.slug).slice(0, 3);
const marquesAdblue = service.slug === 'suppression-adblue'
  ? Object.values(import.meta.glob('../../data/adblue/*.json', { eager: true })).map((m) => m.default).sort((a, b) => a.nom.localeCompare(b.nom))
  : [];

const description = `${service.accroche} À Cholet et dans le Grand Ouest avec Ultimauto. ${service.prixIndicatif}, devis gratuit.`.slice(0, 155);
const jsonLd = [
  serviceLd({ site, service, url, cat }),
  faqPage(service.faqLocale),
  breadcrumb([{ name: 'Accueil', url: site.url }, { name: service.nom, url }]),
];
---
<Layout title={`${service.titreCourt} — Ultimauto Cholet`} description={description} jsonLd={jsonLd} preloadImage={SERVICE_PHOTO[service.slug]}>
  <!-- Hero (photo réelle + overlay bleu) -->
  <section class="relative overflow-hidden bg-cover bg-center" style={`background-image: linear-gradient(180deg, rgba(25,106,213,0.80) 0%, rgba(21,101,192,0.92) 100%), url('${SERVICE_PHOTO[service.slug]}');`}>
    <div class="mx-auto max-w-[1180px] px-6 py-16 text-white md:py-24">
      <nav aria-label="Fil d'Ariane" class="text-sm text-white/75">
        <a href="/" class="hover:text-white">Accueil</a> <span class="px-1.5">/</span> <span class="text-white">{service.nom}</span>
      </nav>
      <span class="mt-5 inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-3 py-1 text-sm font-semibold text-white">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[service.slug].map((d) => <path d={d} />)}</svg>
        Prestation Ultimauto
      </span>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold leading-tight text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] md:text-5xl">{service.nom}</h1>
      <p class="mt-5 max-w-2xl text-lg text-white/90">{service.intro}</p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href="/prise-de-rendez-vous" class="rounded-full bg-accent px-6 py-3 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Prendre rendez-vous</a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-5 py-2.5 font-semibold text-white transition-colors hover:bg-white/10"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d={WA_PATH} /></svg>Devis WhatsApp</a>
        <span class="rounded-full bg-white/15 px-3 py-1.5 text-sm font-semibold text-white">{service.prixIndicatif}</span>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="section bg-white">
    <div class="mx-auto grid max-w-[1180px] gap-12 px-6 lg:grid-cols-[1.45fr_1fr] lg:items-start">
      <div class="rte max-w-2xl">
        <h2 class="text-2xl font-bold md:text-3xl">En quoi consiste {service.nom.toLowerCase()}&#8239;?</h2>
        <p>{service.description}</p>
        <p>{service.pourquoi}</p>
      </div>
      <div class="rounded-3xl border border-line bg-cloud p-6 lg:sticky lg:top-28">
        <p class="font-display text-lg font-bold">L'essentiel</p>
        <dl class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between gap-3"><dt class="text-ink-500">Prestation</dt><dd class="text-right font-semibold">{service.titreCourt}</dd></div>
          <div class="flex justify-between gap-3"><dt class="text-ink-500">À partir de</dt><dd class="text-right font-semibold">{service.prixIndicatif}</dd></div>
          <div class="flex justify-between gap-3"><dt class="text-ink-500">Atelier</dt><dd class="text-right font-semibold">Cholet (49)</dd></div>
          <div class="flex justify-between gap-3"><dt class="text-ink-500">Zone</dt><dd class="text-right font-semibold">44 · 49 · 56 · 79 · 85</dd></div>
          <div class="flex justify-between gap-3"><dt class="text-ink-500">Service mobile</dt><dd class="text-right font-semibold text-accent-700">Oui</dd></div>
          <div class="flex justify-between gap-3"><dt class="text-ink-500">Devis</dt><dd class="text-right font-semibold text-accent-700">Gratuit</dd></div>
        </dl>
        <a href="/prise-de-rendez-vous" class="btn-primary mt-5 w-full">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- Méthode -->
  {service.methode && (
    <section class="section bg-cloud">
      <div class="mx-auto max-w-[1180px] px-6">
        <h2 class="text-2xl font-bold md:text-3xl">Notre méthode</h2>
        <div class="mt-6 grid gap-5 md:grid-cols-3">
          {service.methode.map((m, i) => (
            <div class="rounded-2xl border border-line bg-white p-6">
              <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 font-display text-lg font-extrabold text-brand">{i + 1}</span>
              <h3 class="mt-4 text-lg font-bold">{m.titre}</h3>
              <p class="mt-2 text-sm text-ink-700">{m.texte}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Symptômes + bénéfices -->
  <section class="section bg-white">
    <div class="mx-auto grid max-w-[1180px] gap-12 px-6 lg:grid-cols-2">
      <div>
        <h2 class="text-2xl font-bold md:text-3xl">Les signes qui doivent vous alerter</h2>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2">
          {service.symptomes.map((s) => (
            <li class="rounded-2xl border border-line bg-cloud p-5">
              <h3 class="font-bold text-ink">{s.titre}</h3>
              <p class="mt-1.5 text-sm text-ink-700">{s.texte}</p>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="text-2xl font-bold md:text-3xl">Les bénéfices</h2>
        <ul class="mt-6 space-y-3">
          {service.benefices.map((b) => (
            <li class="flex items-start gap-3 rounded-xl border border-line bg-white p-4">
              <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 shrink-0 text-accent-600" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
              <span class="text-ink-700">{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Pour aller plus loin : maillage hub → blog -->
  {relatedPosts.length > 0 && (
    <section class="section bg-white">
      <div class="mx-auto max-w-[1180px] px-6">
        <h2 class="text-2xl font-bold md:text-3xl">Pour aller plus loin</h2>
        <p class="mt-2 text-ink-600">Nos guides pour comprendre {service.titreCourt.toLowerCase()} en détail.</p>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {relatedPosts.map((p) => (
            <a href={`/blog/${p.id}`} class="group flex flex-col rounded-2xl border border-line bg-white p-5 transition-all hover:-translate-y-1 hover:shadow-[var(--shadow-card)]">
              <h3 class="font-bold leading-snug transition-colors group-hover:text-brand">{p.data.title}</h3>
              <p class="mt-2 flex-1 text-sm text-ink-700">{p.data.description}</p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-bold text-brand">Lire l'article →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Problème AdBlue par marque (hub AdBlue uniquement) -->
  {marquesAdblue.length > 0 && (
    <section class="section bg-cloud">
      <div class="mx-auto max-w-[1180px] px-6">
        <span class="eyebrow">Par marque</span>
        <h2 class="mt-2 text-2xl font-bold md:text-3xl">Problème AdBlue&#160;: trouvez votre marque</h2>
        <p class="mt-2 max-w-2xl text-ink-700">Les pannes AdBlue sont souvent spécifiques au constructeur. Sélectionnez votre marque pour les symptômes, codes défaut et nos solutions.</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {marquesAdblue.map((m) => (
            <a href={`/probleme-adblue/${m.slug}`} class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-ink-700 ring-1 ring-line transition-all hover:-translate-y-0.5 hover:bg-brand hover:text-white hover:ring-brand">{m.nom}</a>
          ))}
        </div>
        <a href="/probleme-adblue" class="btn-ghost mt-6">Voir toutes les marques →</a>
      </div>
    </section>
  )}

  <!-- Valeurs éco -->
  <EcoValues />

  <!-- Étapes + cas d'usage / légal -->
  <section class="section bg-cloud">
    <div class="mx-auto grid max-w-[1180px] gap-12 px-6 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="text-2xl font-bold md:text-3xl">Comment ça se passe</h2>
        <ol class="mt-6 space-y-5">
          {service.etapes.map((e, i) => (
            <li class="flex gap-4">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-brand font-display text-sm font-bold text-white">{i + 1}</span>
              <div><h3 class="font-bold text-ink">{e.titre}</h3><p class="mt-1 text-sm text-ink-700">{e.texte}</p></div>
            </li>
          ))}
        </ol>
      </div>
      <div class="space-y-6">
        <div class="rounded-3xl border border-line bg-white p-6">
          <h3 class="text-lg font-bold">Dans quels cas intervenir&#8239;?</h3>
          <ul class="mt-3 space-y-2">
            {service.casUsage.map((cas) => (
              <li class="flex items-start gap-2.5 text-ink-700">
                <svg viewBox="0 0 24 24" class="mt-1 h-4 w-4 shrink-0 text-accent-600" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
                <span>{cas}</span>
              </li>
            ))}
          </ul>
        </div>
        {service.legalNote && (
          <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-900">
            <p class="font-bold">⚠️ Information importante</p>
            <p class="mt-1.5">{service.legalNote}</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  {cat && (
    <section class="section bg-white">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl">Tarifs {service.titreCourt.toLowerCase()}</h2>
        <p class="mt-2 text-ink-700">Tarifs TTC à l'atelier de Cholet. En service mobile, des frais de déplacement peuvent s'appliquer.</p>
        <div class="mt-6 divide-y divide-line overflow-hidden rounded-2xl border border-line bg-white">
          {cat.formules.map((f) => (
            <div class="flex items-start justify-between gap-4 p-5">
              <div>
                <p class="font-semibold text-ink">{f.nom}</p>
                {f.desc && <p class="mt-1 text-sm text-ink-700">{f.desc}</p>}
                {f.cadeau && <span class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-accent-50 px-2.5 py-1 text-xs font-semibold text-accent-700">🎁 {f.cadeau}</span>}
              </div>
              <span class="shrink-0 whitespace-nowrap font-display text-lg font-extrabold text-brand">{f.prix}</span>
            </div>
          ))}
        </div>
        {cat.note && <p class="mt-3 text-sm text-ink-500">{cat.note}</p>}
        <a href="/tarifs" class="btn-ghost mt-5">Voir tous les tarifs</a>
      </div>
    </section>
  )}

  <!-- Galerie photos réelles -->
  <Gallery />

  <!-- Maillage villes (services locaux) -->
  {service.local && villesMaillage.length > 0 && (
    <section class="section bg-deep text-white">
      <div class="mx-auto max-w-[1180px] px-6">
        <span class="eyebrow text-white">Près de chez vous</span>
        <h2 class="mt-2 text-2xl font-bold text-white md:text-3xl">{service.titreCourt} dans votre commune</h2>
        <p class="mt-2 max-w-2xl text-white">Nous intervenons dans de nombreuses communes du Grand Ouest. Trouvez la vôtre&#160;:</p>
        <div class="mt-7 grid grid-cols-2 gap-2.5 sm:grid-cols-3 lg:grid-cols-4">
          {villesMaillage.map((vv) => (
            <a href={`/${service.slug}/${villeSlug(vv)}`} class="flex items-center justify-between rounded-xl bg-black/30 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-black/40">
              <span>{vv.nom}</span><span class="text-xs text-white/80">{vv.dept}</span>
            </a>
          ))}
        </div>
        <a href="/zones-d-intervention" class="mt-6 inline-flex rounded-full bg-accent px-6 py-3 font-display font-extrabold text-ink transition-transform hover:-translate-y-0.5">Toutes les zones d'intervention</a>
      </div>
    </section>
  )}

  {!service.local && (
    <section class="section bg-deep text-white">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-2xl font-bold text-white md:text-3xl">À Cholet et dans tout le Grand Ouest</h2>
        <p class="mt-3 text-white">Basés à Cholet, nous réalisons cette prestation à l'atelier et, grâce à notre service mobile, à votre domicile ou sur votre lieu de travail dans le Maine-et-Loire, la Loire-Atlantique, la Vendée, les Deux-Sèvres et le Morbihan.</p>
        <a href="/zones-d-intervention" class="mt-6 inline-flex rounded-full bg-accent px-6 py-3 font-display font-extrabold text-ink">Nos zones d'intervention</a>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section bg-white">
    <div class="mx-auto max-w-3xl px-6">
      <span class="eyebrow">FAQ</span>
      <h2 class="mt-2 text-2xl font-bold md:text-3xl">Questions fréquentes</h2>
      <div class="mt-8 divide-y divide-line overflow-hidden rounded-2xl border border-line bg-white">
        {service.faqLocale.map((f) => (
          <details class="group px-6">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-semibold text-ink [&::-webkit-details-marker]:hidden">
              {f.q}
              <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 text-brand transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14" /></svg>
            </summary>
            <p class="pb-5 text-ink-700">{f.r}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Autres services -->
  <section class="section bg-cloud">
    <div class="mx-auto max-w-[1180px] px-6">
      <h2 class="text-2xl font-bold md:text-3xl">Nos autres prestations</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {autres.map((s) => (
          <a href={`/${s.slug}`} class="group flex items-center gap-4 rounded-2xl border border-line bg-white p-5 transition-colors hover:border-brand-200">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[s.slug].map((d) => <path d={d} />)}</svg></span>
            <span><span class="block font-bold leading-tight">{s.titreCourt}</span><span class="mt-0.5 block text-sm text-ink-500">{s.prixIndicatif}</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-deep to-brand py-16 text-white">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">{service.nom}&#160;: demandez votre devis gratuit</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">{service.accroche}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/prise-de-rendez-vous" class="rounded-full bg-accent px-7 py-3.5 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Prendre rendez-vous</a>
        <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white hover:bg-white/10">{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</Layout>
