---
// Page de pilotage du mode maintenance (bouton ON/OFF).
// Accès : https://ultimauto.fr/pilote?cle=VOTRE_SECRET
// La bascule réelle est protégée par le secret côté API (/api/maintenance).
export const prerender = true;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Pilotage — Ultimauto</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background:#eef2f7;color:#0f172a;min-height:100vh;display:grid;place-items:center;padding:20px}
    .card{background:#fff;width:100%;max-width:440px;border-radius:24px;overflow:hidden;box-shadow:0 24px 60px rgba(15,76,146,.18)}
    .head{background:linear-gradient(160deg,#0f4c92,#1565C0);color:#fff;padding:26px 26px 22px;text-align:center}
    .logo{font-weight:800;font-size:22px;letter-spacing:-.5px}
    .logo b{color:#8BC53F}
    .head p{margin-top:4px;font-size:13px;color:#cfe0f5}
    .body{padding:26px}
    .state{display:flex;align-items:center;gap:12px;padding:16px 18px;border-radius:16px;font-weight:700;font-size:16px;margin-bottom:22px}
    .state .dot{width:14px;height:14px;border-radius:50%;flex:none}
    .on{background:#fef2f2;color:#b91c1c}.on .dot{background:#ef4444;box-shadow:0 0 0 4px #fee2e2}
    .off{background:#f0fdf4;color:#15803d}.off .dot{background:#22c55e;box-shadow:0 0 0 4px #dcfce7}
    .loading{background:#f1f5f9;color:#64748b}.loading .dot{background:#94a3b8}
    button{width:100%;border:0;border-radius:999px;padding:16px;font-size:16px;font-weight:800;cursor:pointer;transition:transform .1s,filter .15s}
    button:active{transform:scale(.98)}
    button:disabled{opacity:.5;cursor:not-allowed}
    .btn-on{background:#ef4444;color:#fff}
    .btn-off{background:#22c55e;color:#fff}
    .hint{margin-top:16px;font-size:13px;line-height:1.5;color:#64748b;text-align:center}
    .hint a{color:#1565C0;font-weight:600;text-decoration:none}
    .keybox{display:flex;gap:8px;margin-bottom:18px}
    .keybox input{flex:1;padding:13px 14px;border:1px solid #cbd5e1;border-radius:12px;font-size:15px}
    .keybox button{width:auto;padding:13px 20px;background:#1565C0;color:#fff;font-size:14px}
    .msg{margin-top:14px;font-size:13.5px;text-align:center;min-height:18px;font-weight:600}
    .msg.err{color:#b91c1c}.msg.ok{color:#15803d}
  </style>
</head>
<body>
  <div class="card">
    <div class="head">
      <div class="logo">ultim<b>auto</b></div>
      <p>Pilotage du site</p>
    </div>
    <div class="body">
      <div id="needkey" hidden>
        <p style="font-size:14px;color:#475569;margin-bottom:12px;">Entrez votre clé d'accès :</p>
        <div class="keybox">
          <input id="key" type="password" placeholder="Clé secrète" autocomplete="off" />
          <button id="keybtn" type="button">OK</button>
        </div>
      </div>

      <div id="panel" hidden>
        <div id="state" class="state loading"><span class="dot"></span><span id="statetxt">Vérification…</span></div>
        <button id="toggle" type="button" disabled>…</button>
        <div id="msg" class="msg"></div>
        <p class="hint">
          En maintenance, seuls les visiteurs voient la page « bientôt de retour » (les moteurs reçoivent un code&nbsp;503, sans impact SEO). <br />
          <a id="seesite" href="#" target="_blank" rel="noopener">Voir le site en tant que propriétaire →</a>
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(location.search);
      var cle = params.get('cle') || sessionStorage.getItem('ua_cle') || '';
      var needkey = document.getElementById('needkey');
      var panel = document.getElementById('panel');
      var stateEl = document.getElementById('state');
      var stateTxt = document.getElementById('statetxt');
      var toggle = document.getElementById('toggle');
      var msg = document.getElementById('msg');
      document.getElementById('seesite').href = '/?acces=acces-prive-ultimauto';

      var current = null;

      function render(on) {
        current = on;
        stateEl.className = 'state ' + (on ? 'on' : 'off');
        stateTxt.textContent = on ? 'Site EN MAINTENANCE' : 'Site EN LIGNE';
        toggle.className = on ? 'btn-off' : 'btn-on';
        toggle.textContent = on ? '✅ Remettre le site en ligne' : '🛠️ Activer la maintenance';
        toggle.disabled = false;
      }
      function setMsg(t, ok) { msg.textContent = t || ''; msg.className = 'msg ' + (ok ? 'ok' : 'err'); }

      function api(method, body) {
        var url = '/api/maintenance' + (method === 'GET' ? '?cle=' + encodeURIComponent(cle) : '');
        var opt = { method: method, headers: { 'Content-Type': 'application/json' } };
        if (body) opt.body = JSON.stringify(Object.assign({ cle: cle }, body));
        return fetch(url, opt).then(function (r) { return r.json().then(function (j) { return { status: r.status, j: j }; }); });
      }

      function load() {
        api('GET').then(function (res) {
          if (res.status === 401) { showKey(true); setMsg('Clé incorrecte.', false); return; }
          if (res.status >= 500) { panel.hidden = false; needkey.hidden = true; setMsg('Configuration Vercel manquante (Edge Config / token).', false); return; }
          sessionStorage.setItem('ua_cle', cle);
          needkey.hidden = true; panel.hidden = false;
          render(res.j.on === true);
        }).catch(function () { setMsg('Erreur réseau.', false); });
      }

      function showKey(force) {
        if (cle && !force) { load(); return; }
        needkey.hidden = false; panel.hidden = true;
      }

      document.getElementById('keybtn').onclick = function () {
        cle = document.getElementById('key').value.trim();
        if (cle) load();
      };
      document.getElementById('key').addEventListener('keydown', function (e) { if (e.key === 'Enter') document.getElementById('keybtn').click(); });

      toggle.onclick = function () {
        var next = !current;
        if (next && !confirm('Activer le mode maintenance ? Les visiteurs ne verront plus le site.')) return;
        toggle.disabled = true; setMsg('…', true);
        api('POST', { on: next }).then(function (res) {
          if (res.status === 200) { render(res.j.on); setMsg(res.j.on ? 'Maintenance activée.' : 'Site remis en ligne.', true); }
          else { toggle.disabled = false; setMsg(res.j && res.j.error ? res.j.error : 'Échec.', false); }
        }).catch(function () { toggle.disabled = false; setMsg('Erreur réseau.', false); });
      };

      showKey(false);
    })();
  </script>
</body>
</html>
