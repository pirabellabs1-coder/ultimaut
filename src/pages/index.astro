        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/10">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={WA_PATH} /></svg>
          Devis WhatsApp
        </a>
        <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 rounded-full px-5 py-3 font-bold text-white hover:text-accent">{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</Layout>
