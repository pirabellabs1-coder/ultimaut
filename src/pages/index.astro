---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import services from '../data/services.json';
import tarifs from '../data/tarifs.json';
import avisData from '../data/avis.json';
import { WA_PATH, ICONS } from '../lib/ui.js';
import { villeSlug } from '../lib/slug.js';
import { villesPourService } from '../lib/pages.js';
import { faqPage } from '../lib/jsonld.js';

const waLink = `https://wa.me/${site.whatsapp}`;
const principaux = services.filter((s) => s.local);
const autres = services.filter((s) => !s.local);
const bySlug = Object.fromEntries(services.map((s) => [s.slug, s]));
const deca = bySlug['decalaminage-hydrogene'];
const fap = bySlug['nettoyage-fap'];
const reprog = bySlug['reprogrammation-moteur'];
const adblue = bySlug['suppression-adblue'];

const reassurance = [
  'Sans démontage moteur',
  'Devis gratuit & sans engagement',
  'Service mobile à domicile ou au travail',
  'Revendeur agréé Bardahl',
];

const chiffres = [
  { n: '30–60 min', l: "Durée d'un décalaminage" },
  { n: 'Dès 80 €', l: 'Décalaminage hydrogène' },
  { n: '5', l: 'départements (44·49·56·79·85)' },
  { n: '110+', l: 'communes desservies' },
];

const process = [
  { t: 'Prise de contact', d: 'Appelez-nous, écrivez sur WhatsApp (une photo ou une vidéo aide beaucoup) ou remplissez le formulaire. On cerne votre besoin et on vous propose un créneau.' },
  { t: 'Diagnostic', d: "On lit les codes défaut et on vérifie l'état réel de votre moteur. Pas d'intervention inutile : on vous explique précisément ce dont votre véhicule a besoin." },
  { t: 'Intervention', d: 'Décalaminage, nettoyage FAP, reprogrammation… réalisés avec un matériel professionnel, sans démontage quand c’est possible, dans le respect de votre mécanique.' },
  { t: 'Restitution & conseils', d: 'On contrôle le résultat, on vous remet le véhicule et on vous donne des conseils d’entretien adaptés à votre usage.' },
];

const pourquoi = [
  { t: 'Le diagnostic avant tout', d: 'On ne devine pas, on diagnostique. Chaque prestation commence par une vérification pour cibler la vraie cause du problème, pas seulement le symptôme.' },
  { t: 'Transparence totale', d: 'Devis gratuit et détaillé, explications claires, aucune mauvaise surprise. Vous décidez en connaissance de cause, sans pression.' },
  { t: 'Réparer plutôt que remplacer', d: 'Un FAP peut souvent être nettoyé au lieu d’être remplacé, pour bien moins cher. On privilégie la solution la plus durable et la plus économique.' },
  { t: 'Atelier + service mobile', d: 'Venez à notre atelier de Cholet, ou faites-nous venir à vous — à domicile ou sur votre lieu de travail, partout dans le Grand Ouest.' },
];

const signes = [
  { t: 'Perte de puissance', d: 'Le moteur répond moins bien, surtout à bas régime : la calamine ou un FAP encrassé étouffent la mécanique.' },
  { t: 'Surconsommation', d: 'Votre consommation grimpe sans avoir changé de conduite ? Un moteur encrassé brûle mal le carburant.' },
  { t: 'Fumées à l’échappement', d: 'Des fumées noires ou grises trahissent une combustion incomplète et un encrassement avancé.' },
  { t: 'Voyant moteur ou FAP', d: 'Un voyant allumé signale souvent un souci d’admission, d’EGR ou un filtre à particules saturé.' },
  { t: 'Ralenti instable, à-coups', d: 'Soupapes et vanne EGR encrassées provoquent un ralenti irrégulier et des broutements en conduite.' },
  { t: 'Passage en mode dégradé', d: 'Puissance bridée par l’électronique : un signal à ne pas ignorer, souvent lié au filtre à particules.' },
];

const ideesRecues = [
  { faux: 'Un FAP bouché, il faut forcément le remplacer.', vrai: 'Tant que la céramique n’est pas fondue ni fissurée, un nettoyage en profondeur restitue ses performances — pour bien moins cher qu’un FAP neuf.' },
  { faux: 'Le décalaminage abîme le moteur.', vrai: 'Non : on injecte seulement de l’hydrogène dans l’admission, sans démontage ni produit chimique versé dans le moteur. C’est une opération douce et maîtrisée.' },
  { faux: 'Une reprogrammation casse le moteur.', vrai: 'Pas si elle est bien faite. Une cartographie Stage 1 sérieuse, réalisée sur un moteur sain, reste dans les marges de fiabilité de la mécanique.' },
  { faux: 'Rouler sur autoroute nettoie le moteur.', vrai: 'Cela aide la régénération du FAP, mais ne décolle pas la calamine déjà incrustée sur les soupapes, l’EGR et le turbo.' },
];

const typesVehicules = [
  'Citadines & berlines (diesel et essence)',
  'Utilitaires & véhicules de société',
  'SUV, breaks & monospaces familiaux',
  'Flottes et professionnels',
];

const faq = [
  { q: 'Qu’est-ce que le décalaminage à l’hydrogène, concrètement ?', r: 'Avec une station professionnelle, on injecte de l’hydrogène dans l’admission pendant que le moteur tourne. Ce gaz améliore la combustion et aide à décoller la calamine (les dépôts de carbone) accumulée sur les soupapes, les injecteurs, la vanne EGR et le turbo. Les résidus sont ensuite évacués par l’échappement, sans démontage et sans produit chimique versé dans le moteur.' },
  { q: 'Tous les combien faut-il faire un décalaminage ?', r: 'Pour un usage urbain ou de petits trajets, un décalaminage tous les 15 000 à 30 000 km est un bon rythme préventif. Sur un moteur déjà encrassé, il agit comme une cure ponctuelle. On vous conseille selon votre kilométrage et votre façon de rouler.' },
  { q: 'Vaut-il mieux nettoyer ou remplacer un FAP ?', r: 'Tant que la céramique du filtre n’est ni fondue ni fissurée, le nettoyage est presque toujours possible — et coûte bien moins cher qu’un FAP neuf. On vérifie l’état du filtre avant toute intervention et on vous dit honnêtement ce qui est récupérable.' },
  { q: 'La suppression AdBlue est-elle autorisée sur route ?', r: 'Non. Modifier un système anti-pollution sur un véhicule qui circule sur la voie publique n’est pas autorisé en France. Cette prestation est strictement réservée à un usage hors route (circuit fermé, compétition, export, véhicule non homologué). On vous informe clairement de ce cadre avant toute décision.' },
  { q: 'Combien de temps prend une intervention ?', r: 'Un décalaminage dure 30 à 60 minutes selon la cylindrée. Un nettoyage FAP ou une reprogrammation se réalisent généralement dans la journée. On organise le rendez-vous pour limiter votre immobilisation.' },
  { q: 'Intervenez-vous à domicile ?', r: 'Oui. En plus de notre atelier de Cholet, notre service mobile se déplace chez vous ou sur votre lieu de travail dans le Maine-et-Loire, la Loire-Atlantique, la Vendée, les Deux-Sèvres et le Morbihan (des frais de déplacement peuvent s’appliquer selon la distance).' },
];

const tarifApercu = tarifs.categories.filter((c) =>
  ['decalaminage-hydrogene', 'nettoyage-fap', 'reprogrammation-moteur'].includes(c.service)
);

const avisHome = avisData.items.slice(0, 6);

const zonesParService = principaux.map((s) => ({
  service: s,
  villes: villesPourService(s.slug).slice(0, 10),
}));

const jsonLd = [faqPage(faq)];
const title = 'Ultimauto — Décalaminage hydrogène & nettoyage FAP à Cholet';
const description = "Spécialiste du décalaminage hydrogène et du nettoyage FAP à Cholet. Reprogrammation, AdBlue, service mobile dans le Grand Ouest. Devis gratuit.";
---

<Layout title={title} description={description} jsonLd={jsonLd}>
  <!-- ============================== HERO ============================== -->
  <section
    class="relative overflow-hidden bg-cover bg-center"
    style="background-image: linear-gradient(180deg, rgba(25,106,213,0.72) 0%, rgba(25,106,213,0.80) 55%, rgba(25,106,213,0.88) 100%), url('/img/hero-1.jpg');"
  >
    <div class="mx-auto flex min-h-[600px] max-w-[1320px] flex-col items-center justify-center px-6 py-20 text-center">
      <div class="max-w-[820px]">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-4 py-1.5 text-[12px] font-bold uppercase tracking-[0.18em] text-white">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          Centre multiservices automobile · Cholet
        </span>
        <h1 class="mt-6 font-display text-[28px] font-extrabold leading-[1.12] text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] sm:text-[34px] lg:text-[42px]">
          Spécialiste du décalaminage moteur <span class="text-accent">à l'hydrogène</span> &amp; nettoyage FAP
        </h1>
        <p class="mx-auto mt-6 max-w-[600px] text-[17px] leading-relaxed text-white/90 md:text-[18px]">
          Ultimauto redonne souffle, fiabilité et propreté à votre moteur — sans démontage.
          Décalaminage, nettoyage FAP, reprogrammation et gestion AdBlue, à l'atelier de Cholet
          ou en service mobile dans tout le Grand Ouest.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/prise-de-rendez-vous" class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3.5 font-display text-base font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">
            Prendre rendez-vous
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 bg-white/10 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/20">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={WA_PATH} /></svg>
            Devis WhatsApp
          </a>
        </div>
        <ul class="mt-9 flex flex-wrap justify-center gap-x-7 gap-y-3 text-sm font-semibold text-white/90">
          {['Sans démontage moteur', 'Devis gratuit & sans engagement', 'Revendeur agréé Bardahl'].map((t) => (
            <li class="inline-flex items-center gap-2">
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {t}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ===================== RÉASSURANCE ===================== -->
  <div class="border-b border-line bg-white">
    <div class="mx-auto grid max-w-[1180px] grid-cols-2 gap-x-6 gap-y-4 px-6 py-6 lg:grid-cols-4">
      {reassurance.map((t) => (
        <div class="flex items-center gap-3">
          <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent-50 text-accent-700">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
          </span>
          <span class="text-sm font-semibold leading-tight text-ink">{t}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ===================== À PROPOS ===================== -->
  <section class="section bg-white">
    <div class="mx-auto grid max-w-[1180px] items-center gap-12 px-6 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Bienvenue chez Ultimauto</span>
        <h2 class="mt-3 text-3xl font-extrabold md:text-4xl">Le spécialiste de l'entretien moteur dans le Grand Ouest</h2>
        <div class="rte mt-6">
          <p>Basé à <strong>Cholet</strong>, dans le Maine-et-Loire, Ultimauto est un centre multiservices automobile spécialisé dans le <strong>décalaminage moteur à l'hydrogène</strong> et le <strong>nettoyage du filtre à particules (FAP)</strong>, sans démontage. Notre métier : redonner du souffle, de la fiabilité et de la propreté à votre moteur, tout en maîtrisant votre budget.</p>
          <p>Au fil des kilomètres, surtout en ville et sur les petits trajets, un moteur s'encrasse : la calamine s'accumule, le FAP se colmate, les performances baissent et la consommation grimpe. Plutôt que de remplacer des pièces coûteuses, nous traitons la cause avec des méthodes propres et éprouvées. Et parce que chaque véhicule est différent, tout commence par un <strong>diagnostic honnête</strong> : on vous explique simplement ce qui se passe, et on ne propose que ce qui est réellement utile.</p>
          <p>Décalaminage, nettoyage FAP, reprogrammation moteur, gestion AdBlue, mais aussi destruction d'odeurs, pressing des sièges et rénovation d'optiques de phares : nous intervenons à l'atelier de Cholet comme en <strong>service mobile</strong>, chez vous ou sur votre lieu de travail, dans cinq départements (44, 49, 56, 79 et 85).</p>
        </div>
      </div>
      <div class="relative">
        <img src="/img/photo-2.jpg" alt="Intervention de décalaminage hydrogène Ultimauto en service mobile" width="980" height="735" class="w-full rounded-3xl object-cover shadow-[var(--shadow-card)]" loading="lazy" />
        <div class="absolute -bottom-5 -left-5 hidden rounded-2xl bg-deep px-5 py-4 text-white shadow-lg sm:block">
          <p class="font-display text-2xl font-extrabold leading-none">Cholet</p>
          <p class="mt-1 text-xs text-white/85">Atelier + service mobile · 5 départements</p>
        </div>
        <div class="absolute -right-4 -top-4 hidden rounded-full bg-accent px-4 py-2 font-display text-sm font-extrabold text-ink shadow-lg sm:block">Revendeur agréé Bardahl</div>
      </div>
    </div>
  </section>

  <!-- ===================== VALEURS (éco) ===================== -->
  <section class="section bg-brand-50">
    <div class="mx-auto max-w-[1180px] px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Notre engagement</span>
        <h2 class="mt-3 text-3xl font-extrabold md:text-4xl">Écologique, économique, écocitoyen</h2>
        <p class="mt-4 text-ink-700">C'est la signature d'Ultimauto — et ce n'est pas qu'un slogan. Entretenir un moteur plutôt que remplacer des pièces, c'est bon pour la planète, pour votre portefeuille et pour la collectivité.</p>
      </div>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-line bg-white p-7 text-center">
          <img src="/img/icons/ecologie.png" alt="" width="56" height="56" class="mx-auto h-14 w-14 object-contain" loading="lazy" />
          <h3 class="mt-4 text-lg font-bold">Écologique</h3>
          <p class="mt-2 text-sm text-ink-700">Un moteur décalaminé brûle mieux son carburant et rejette nettement moins de particules. Jusqu'à <strong>−70 % de pollution</strong> annoncés : rouler plus propre, sans changer de voiture.</p>
        </div>
        <div class="rounded-2xl border border-line bg-white p-7 text-center">
          <img src="/img/icons/economie.png" alt="" width="56" height="56" class="mx-auto h-14 w-14 object-contain" loading="lazy" />
          <h3 class="mt-4 text-lg font-bold">Économique</h3>
          <p class="mt-2 text-sm text-ink-700">Le décalaminage peut réduire la consommation jusqu'à <strong>−15 %</strong> et préserve les pièces sensibles (turbo, vanne EGR, FAP, injecteurs). On entretient au lieu de remplacer : la facture reste légère.</p>
        </div>
        <div class="rounded-2xl border border-line bg-white p-7 text-center">
          <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-accent-50 text-accent-700">
            <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3" /><path d="M3.5 20a5.5 5.5 0 0 1 11 0" /><path d="M16 5.2a3 3 0 0 1 0 5.6" /><path d="M18.5 20a5.5 5.5 0 0 0-3-4.9" /></svg>
          </span>
          <h3 class="mt-4 text-lg font-bold">Écocitoyen</h3>
          <p class="mt-2 text-sm text-ink-700">Prolonger la vie de votre véhicule, c'est moins de pièces jetées et moins de déchets. Une démarche responsable, à l'échelle de votre commune comme de la planète.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section class="section bg-cloud">
    <div class="mx-auto max-w-[1180px] px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="eyebrow">Nos prestations</span>
        <h2 class="mt-3 text-3xl font-extrabold md:text-4xl">Tout pour la santé de votre véhicule</h2>
        <p class="mt-4 text-ink-700">Des solutions concrètes pour le moteur comme pour l'habitacle, avec un matériel professionnel et un vrai souci du détail.</p>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {principaux.map((s) => (
          <a href={`/${s.slug}`} class="group flex flex-col rounded-2xl border border-line bg-white p-6 transition-all hover:-translate-y-1 hover:border-brand-200 hover:shadow-[var(--shadow-card)]">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand transition-colors group-hover:bg-brand group-hover:text-white">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[s.slug].map((d) => <path d={d} />)}</svg>
            </span>
            <h3 class="mt-4 text-lg font-bold">{s.titreCourt}</h3>
            <p class="mt-2 flex-1 text-sm text-ink-700">{s.accroche}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-bold text-brand">
              {s.prixIndicatif}
              <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </span>
          </a>
        ))}
      </div>
      <div class="mt-5 grid gap-5 sm:grid-cols-3">
        {autres.map((s) => (
          <a href={`/${s.slug}`} class="group flex items-center gap-4 rounded-2xl border border-line bg-white p-5 transition-colors hover:border-brand-200">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-cloud text-brand">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[s.slug].map((d) => <path d={d} />)}</svg>
            </span>
            <span>
              <span class="block font-bold leading-tight">{s.titreCourt}</span>
              <span class="mt-0.5 block text-sm text-ink-500">{s.prixIndicatif}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== DÉCALAMINAGE EXPLIQUÉ ===================== -->
  <section class="section bg-white">
    <div class="mx-auto grid max-w-[1180px] gap-12 px-6 lg:grid-cols-[1.4fr_1fr] lg:items-start">
      <div>
        <span class="eyebrow">Notre spécialité</span>
        <h2 class="mt-3 text-3xl font-extrabold md:text-4xl">Le décalaminage à l'hydrogène, expliqué simplement</h2>
        <div class="rte mt-5">
          <p>{deca.description}</p>
          <p>{deca.pourquoi}</p>
        </div>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          {deca.benefices.map((b) => (
            <li class="flex items-start gap-2.5 text-sm text-ink-700">
              <svg viewBox="0 0 24 24" class="mt-0.5 h-4 w-4 shrink-0 text-accent-600" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>
      <aside class="lg:sticky lg:top-28">
        <div class="relative overflow-hidden rounded-3xl shadow-[var(--shadow-card)]">
          <img src="/img/photo-1.jpg" alt="Décalaminage hydrogène d'un moteur diesel par Ultimauto" class="aspect-[4/3] w-full object-cover" loading="lazy" />
          <div class="absolute bottom-4 left-4 rounded-xl bg-white/95 px-4 py-2.5 shadow-lg">
            <span class="block text-[11px] font-semibold uppercase tracking-wide text-ink-500">Formule éco dès</span>
            <span class="font-display text-2xl font-extrabold text-brand">80 €</span>
          </div>
        </div>
        <ul class="mt-5 space-y-3 rounded-2xl border border-line bg-cloud p-5 text-sm">
          <li class="flex justify-between border-b border-line pb-2"><span class="text-ink-500">Durée</span><span class="font-semibold">30 à 60 min</span></li>
          <li class="flex justify-between border-b border-line pb-2"><span class="text-ink-500">Démontage</span><span class="font-semibold">Aucun</span></li>
          <li class="flex justify-between border-b border-line pb-2"><span class="text-ink-500">Produit chimique</span><span class="font-semibold">Aucun dans le moteur</span></li>
          <li class="flex justify-between"><span class="text-ink-500">Idéal</span><span class="font-semibold">tous les 15–30 000 km</span></li>
        </ul>
        <a href="/decalaminage-hydrogene" class="btn-primary mt-4 w-full">Tout savoir sur le décalaminage</a>
      </aside>
    </div>
  </section>

  <!-- ===================== FAP EXPLIQUÉ (#196AD5) ===================== -->
  <section class="section bg-deep text-white">
    <div class="mx-auto grid max-w-[1180px] gap-12 px-6 lg:grid-cols-[1fr_1.4fr] lg:items-start">
      <div class="rounded-3xl border border-white/15 bg-white/[0.08] p-7">
        <p class="font-display text-sm font-bold uppercase tracking-wider text-accent">Nettoyer ≠ remplacer</p>
        <p class="mt-3 text-white/90">Remplacer un FAP coûte souvent plusieurs centaines à plusieurs milliers d'euros. Tant que la céramique n'est ni fondue ni fissurée, le nettoyage restitue ses performances pour une fraction du prix.</p>
        <div class="mt-6 space-y-3">
          <div class="flex items-center justify-between rounded-xl bg-white/10 px-4 py-3">
            <span class="text-sm text-white/80">Formule préventive</span><span class="font-display text-lg font-extrabold text-accent">250 €</span>
          </div>
          <div class="flex items-center justify-between rounded-xl bg-white/10 px-4 py-3">
            <span class="text-sm text-white/80">Formule curative</span><span class="font-display text-lg font-extrabold text-accent">350 €</span>
          </div>
          <p class="text-center text-xs text-white/80">🎁 Décalaminage hydrogène offert avec chaque formule</p>
        </div>
      </div>
      <div>
        <span class="eyebrow text-accent">Filtre à particules</span>
        <h2 class="mt-3 text-3xl font-extrabold text-white md:text-4xl">FAP colmaté, voyant allumé, mode dégradé ?</h2>
        <div class="rte mt-5 [&_p]:text-white/90 [&_strong]:text-white">
          <p>{fap.description}</p>
        </div>
        <a href="/nettoyage-fap" class="mt-7 inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 font-display font-extrabold text-ink transition-transform hover:-translate-y-0.5">
          Découvrir le nettoyage FAP
