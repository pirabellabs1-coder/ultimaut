---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
import site from '../data/site.json';
import { ICONS } from '../lib/ui.js';

const principaux = services.filter((s) => s.local);
---
<Layout title="Page introuvable (404)" description="La page demandée n'existe pas ou a été déplacée. Retrouvez les services Ultimauto : décalaminage, FAP, reprogrammation et AdBlue à Cholet.">
  <section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(180deg, rgba(25,106,213,0.84) 0%, rgba(21,101,192,0.94) 100%), url('/img/hero-1.jpg');">
    <div class="mx-auto max-w-[820px] px-6 py-20 text-center text-white md:py-28">
      <p class="font-display text-6xl font-extrabold text-accent">404</p>
      <h1 class="mt-3 text-3xl font-extrabold text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] md:text-4xl">Cette page a fait un tête-à-queue</h1>
      <p class="mx-auto mt-4 max-w-xl text-white/90">La page que vous cherchez n'existe pas ou a été déplacée. Reprenons la route ensemble :</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/" class="rounded-full bg-accent px-6 py-3 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Retour à l'accueil</a>
        <a href="/prise-de-rendez-vous" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white hover:bg-white/10">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="mx-auto max-w-[1180px] px-6">
      <h2 class="text-center text-2xl font-bold md:text-3xl">Nos prestations</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {principaux.map((s) => (
          <a href={`/${s.slug}`} class="group flex items-center gap-3 rounded-2xl border border-line bg-cloud p-5 transition-colors hover:border-brand hover:bg-white">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[s.slug].map((d) => <path d={d} />)}</svg></span>
            <span class="font-bold leading-tight">{s.titreCourt}</span>
          </a>
        ))}
      </div>
      <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm">
        <a href="/tarifs" class="btn-ghost">Tarifs</a>
        <a href="/zones-d-intervention" class="btn-ghost">Zones d'intervention</a>
        <a href="/blog" class="btn-ghost">Blog</a>
        <a href="/faq" class="btn-ghost">FAQ</a>
        <a href="/contact" class="btn-ghost">Contact</a>
      </div>
    </div>
  </section>
</Layout>
