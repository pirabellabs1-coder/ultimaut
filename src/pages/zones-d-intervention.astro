---
import Layout from '../layouts/Layout.astro';
import villes from '../data/villes.json';
import services from '../data/services.json';
import site from '../data/site.json';
import { ICONS } from '../lib/ui.js';
import { villeSlug } from '../lib/slug.js';
import { aUnePage } from '../lib/pages.js';
import { breadcrumb } from '../lib/jsonld.js';

const servicesLocaux = services.filter((s) => s.local);
const labelCourt = {
  'decalaminage-hydrogene': 'Décalaminage',
  'nettoyage-fap': 'Nettoyage FAP',
  'reprogrammation-moteur': 'Reprog.',
  'suppression-adblue': 'AdBlue',
};
const autres = services.filter((s) => !s.local);

const ordreZones = ['Agglomération du Choletais', 'Maine-et-Loire', 'Loire-Atlantique', 'Vendée', 'Deux-Sèvres', 'Morbihan'];
const parZone = {};
for (const v of villes) (parZone[v.zone] ||= []).push(v);
for (const z of Object.keys(parZone)) parZone[z].sort((a, b) => b.population - a.population);
const zones = ordreZones.filter((z) => parZone[z]);

const url = new URL('/zones-d-intervention', site.url).href;
const jsonLd = [breadcrumb([{ name: 'Accueil', url: site.url }, { name: "Zones d'intervention", url }])];
---
<Layout
  title="Zones d'intervention dans le Grand Ouest | Ultimauto"
  description="Toutes les communes desservies par Ultimauto dans le 44, 49, 56, 79 et 85. Choisissez votre prestation et votre ville. Atelier à Cholet + service mobile."
  jsonLd={jsonLd}
>
  <section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(180deg, rgba(25,106,213,0.82) 0%, rgba(21,101,192,0.93) 100%), url('/img/photo-3.jpg');">
    <div class="mx-auto max-w-[1180px] px-6 py-14 text-white md:py-20">
      <nav aria-label="Fil d'Ariane" class="text-sm text-white/75">
        <a href="/" class="hover:text-white">Accueil</a> <span class="px-1.5">/</span> <span class="text-white">Zones d'intervention</span>
      </nav>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] md:text-5xl">Nos zones d'intervention</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/90">
        Depuis notre atelier de Cholet, nous intervenons dans plus de 110 communes du Maine-et-Loire,
        de la Loire-Atlantique, de la Vendée, des Deux-Sèvres et du Morbihan — à l'atelier ou via notre
        service mobile. Choisissez votre prestation et votre commune ci-dessous.
      </p>
    </div>
  </section>

  <!-- Par service -->
  <section class="section bg-white">
    <div class="mx-auto max-w-[1180px] px-6">
      <h2 class="text-2xl font-bold md:text-3xl">Par prestation</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {servicesLocaux.map((s) => (
          <a href={`/${s.slug}`} class="group flex items-center gap-3 rounded-2xl border border-line bg-cloud p-5 transition-colors hover:border-brand hover:bg-white">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-brand-50 text-brand"><svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">{ICONS[s.slug].map((d) => <path d={d} />)}</svg></span>
            <span class="font-bold leading-tight">{s.titreCourt}</span>
          </a>
        ))}
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {autres.map((s) => (
          <a href={`/${s.slug}`} class="flex items-center justify-center gap-2 rounded-xl border border-line px-4 py-3 text-sm font-semibold transition-colors hover:border-brand hover:text-brand">{s.titreCourt}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Par commune (cliquable) -->
  <section class="section bg-cloud">
    <div class="mx-auto max-w-[1180px] space-y-12 px-6">
      {zones.map((z) => (
        <div>
          <div class="flex items-baseline justify-between gap-4 border-b border-line pb-3">
            <h2 class="text-2xl font-bold md:text-3xl">{z}</h2>
            <span class="text-sm text-ink-500">{parZone[z].length} communes</span>
          </div>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {parZone[z].map((v) => {
              const dispo = servicesLocaux.filter((s) => aUnePage(v, s.slug));
              return (
                <div class="rounded-2xl border border-line bg-white p-5">
                  <p class="font-semibold">{v.nom} <span class="text-sm font-normal text-ink-500">({v.dept})</span></p>
                  <div class="mt-2.5 flex flex-wrap gap-1.5">
                    {dispo.map((s) => (
                      <a href={`/${s.slug}/${villeSlug(v)}`} class="rounded-md bg-brand-50 px-2 py-1 text-xs font-semibold text-brand-700 transition-colors hover:bg-brand hover:text-white">{labelCourt[s.slug]}</a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-gradient-to-br from-deep to-brand py-16 text-white">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-extrabold text-white md:text-4xl">Votre commune n'est pas dans la liste ?</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">Nous intervenons dans tout le Grand Ouest, à l'atelier de Cholet ou en service mobile. Contactez-nous pour un devis gratuit.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/prise-de-rendez-vous" class="rounded-full bg-accent px-7 py-3.5 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Prendre rendez-vous</a>
        <a href={`tel:${site.phone}`} class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white hover:bg-white/10">{site.phoneDisplay}</a>
      </div>
    </div>
  </section>
</Layout>
