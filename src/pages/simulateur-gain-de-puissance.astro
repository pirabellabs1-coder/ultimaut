---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import { WA_PATH } from '../lib/ui.js';
import { breadcrumb } from '../lib/jsonld.js';

const waLink = `https://wa.me/${site.whatsapp}`;
const simSrc = 'https://tuning-shop.com/iframe/iframe.php?user=7255';
const url = new URL('/simulateur-gain-de-puissance', site.url).href;
const jsonLd = [breadcrumb([{ name: 'Accueil', url: site.url }, { name: 'Simulateur de gain de puissance', url }])];
---
<Layout
  title="Simulateur de gain de puissance (Stage 1) | Ultimauto"
  description="Estimez gratuitement le gain de puissance et de couple après une reprogrammation Stage 1 selon votre véhicule. Estimation indicative — Ultimauto Cholet."
  jsonLd={jsonLd}
  ogImage="/img/photo-3.jpg"
  preloadImage="/img/photo-3.jpg"
>
  <!-- Hero (compact) -->
  <section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(180deg, rgba(25,106,213,0.82) 0%, rgba(21,101,192,0.93) 100%), url('/img/photo-3.jpg');">
    <div class="mx-auto max-w-[1180px] px-5 py-10 text-white sm:px-6 md:py-16">
      <nav aria-label="Fil d'Ariane" class="text-sm text-white/75"><a href="/" class="hover:text-white">Accueil</a> <span class="px-1.5">/</span> <span class="text-white">Simulateur</span></nav>
      <h1 class="mt-3 max-w-3xl text-3xl font-extrabold text-white [text-shadow:0_2px_18px_rgba(0,0,0,0.35)] sm:text-4xl md:text-5xl">Simulateur de gain de puissance</h1>
      <p class="mt-3 max-w-2xl text-base text-white/90 sm:text-lg">Marque, modèle, motorisation&#160;: estimez le gain de puissance et de couple après une reprogrammation <strong>Stage&nbsp;1</strong>.</p>
    </div>
  </section>

  <!-- Simulateur -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-[920px] px-5 sm:px-6">

      <!-- Carte de lancement (état par défaut, pas d'espace vide) -->
      <div data-sim-card class="rounded-3xl border border-line bg-gradient-to-br from-brand-50 to-cloud p-7 text-center shadow-[var(--shadow-soft)] sm:p-10">
        <span class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-white text-brand shadow-sm ring-1 ring-brand/10">
          <svg viewBox="0 0 24 24" class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="m13.4 12.6 4-4"/><path d="M12 3a9 9 0 0 0-9 9 9 9 0 0 0 1.6 5.1"/><path d="M21 12a9 9 0 0 0-9-9"/><path d="M19.4 17.1A9 9 0 0 0 21 12"/><path d="M6 20h12"/></svg>
        </span>
        <h2 class="mt-4 text-xl font-bold sm:text-2xl">Estimez votre gain en 30&nbsp;secondes</h2>
        <p class="mx-auto mt-2 max-w-md text-ink-700">Sélectionnez votre véhicule pour découvrir la puissance et le couple estimés après une reprogrammation <strong>Stage&nbsp;1</strong>.</p>
        <div class="mt-5 flex flex-wrap justify-center gap-2">
          <span class="chip">Stage 1</span>
          <span class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-ink-700 ring-1 ring-line">Gratuit</span>
          <span class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-ink-700 ring-1 ring-line">Sans engagement</span>
          <span class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-ink-700 ring-1 ring-line">Reprog dès 350 €</span>
        </div>
        <button type="button" data-sim-launch class="btn-primary mt-6 gap-2">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          Lancer le simulateur
        </button>
        <p class="mt-3 text-xs text-ink-500">Estimation indicative — confirmée lors du diagnostic à l'atelier de Cholet.</p>
      </div>

      <!-- Note aperçu local (hors ultimauto.fr) -->
      <div data-sim-localnote hidden class="mt-5 rounded-2xl border border-amber-200 bg-amber-50 p-5 text-sm text-amber-900">
        <p class="font-bold">ℹ️ Aperçu local</p>
        <p class="mt-1">Le simulateur (tuning-shop.com) est <strong>verrouillé sur le domaine ultimauto.fr</strong>. En local, le cadre reste vide — c'est normal. Il fonctionne sur le site en ligne.</p>
      </div>

      <!-- Cadre simulateur (révélé au clic) -->
      <div data-sim-frame hidden class="mt-2">
        <div class="overflow-hidden rounded-3xl border border-line bg-white shadow-[var(--shadow-soft)]">
          <div class="flex items-center gap-2 border-b border-line bg-cloud px-5 py-3">
            <svg viewBox="0 0 24 24" class="h-5 w-5 text-brand" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="m13.4 12.6 4-4"/><path d="M3 12a9 9 0 1 1 18 0"/><path d="M6 20h12"/></svg>
            <p class="font-display text-sm font-bold">Simulateur Stage&nbsp;1 — sélectionnez votre véhicule</p>
          </div>
          <iframe
            id="tuning-sim"
            data-src={simSrc}
            title="Simulateur de gain de puissance Ultimauto"
            loading="lazy"
            scrolling="auto"
            referrerpolicy="strict-origin-when-cross-origin"
            class="block h-[520px] w-full md:h-[480px]"
            style="border:0; background:#fff;"
          ></iframe>
        </div>
        <p class="mt-3 text-center text-sm text-ink-500">Le simulateur ne s'affiche pas&#8239;? <a href={simSrc} target="_blank" rel="noopener" class="font-semibold text-brand underline">Ouvrez-le dans un nouvel onglet</a>.</p>
      </div>

      <!-- CTAs -->
      <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row sm:flex-wrap">
        <a href="/prise-de-rendez-vous" class="btn-primary">Demander un devis Stage 1</a>
        <a href={waLink} target="_blank" rel="noopener" class="btn-whatsapp"><svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d={WA_PATH} /></svg>Devis WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Comment lire -->
  <section class="bg-cloud py-12 md:py-16">
    <div class="mx-auto max-w-3xl px-5 text-center sm:px-6">
      <h2 class="text-2xl font-bold md:text-3xl">Comment lire votre estimation&#8239;?</h2>
      <p class="mt-3 text-ink-700">La reprogrammation Stage 1 optimise la cartographie d'origine de votre moteur pour libérer le potentiel laissé par le constructeur&#160;: davantage de couple disponible plus tôt, des reprises plus franches et, à allure stabilisée, une consommation souvent maîtrisée. Chez Ultimauto, nous travaillons sur une base mécanique saine, nous sauvegardons systématiquement la cartographie d'origine (retour arrière possible) et nous validons le résultat par un essai.</p>
      <a href="/reprogrammation-moteur" class="btn-ghost mt-5">Tout savoir sur la reprogrammation</a>
    </div>
  </section>

  <script>
    (() => {
      const card = document.querySelector('[data-sim-card]');
      const frame = document.querySelector('[data-sim-frame]');
      const note = document.querySelector('[data-sim-localnote]');
      const iframe = document.getElementById('tuning-sim');
      const btn = document.querySelector('[data-sim-launch]');
      const isLive = /(^|\.)ultimauto\.fr$/.test(location.hostname);

      btn?.addEventListener('click', () => {
        if (iframe && !iframe.src) iframe.src = iframe.dataset.src;
        if (card) card.hidden = true;
        if (frame) frame.hidden = false;
        if (!isLive && note) note.hidden = false;
        frame?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      // Redimensionnement auto si tuning-shop transmet sa hauteur (sinon hauteur responsive du CSS).
      window.addEventListener('message', (e) => {
        if (!iframe) return;
        let h = null;
        if (typeof e.data === 'number') h = e.data;
        else if (e.data && typeof e.data === 'object' && (e.data.height || e.data.iframeHeight)) h = e.data.height || e.data.iframeHeight;
        else if (typeof e.data === 'string' && /^\d+$/.test(e.data)) h = parseInt(e.data, 10);
        if (h && h > 300 && h < 2000) iframe.style.height = h + 'px';
      });
    })();
  </script>
</Layout>
