---
import site from '../data/site.json';
import { WA_PATH } from '../lib/ui.js';
const { ville } = Astro.props;
const waLink = `https://wa.me/${site.whatsapp}`;
const lieu = ville ? `à ${ville}` : 'chez vous';
const sousTitre = ville
  ? `Pas le temps de passer à l'atelier ? Notre service mobile vient à ${ville}, à votre domicile ou sur votre lieu de travail. Vous récupérez un moteur plus propre, sans contrainte d'organisation.`
  : `Pas le temps de passer à l'atelier ? Notre service mobile vient à vous, à domicile ou sur votre lieu de travail, partout dans le Grand Ouest. Vous récupérez un moteur plus propre, sans contrainte.`;
---
<section class="relative overflow-hidden bg-cover bg-center" style="background-image: linear-gradient(100deg, rgba(21,101,192,0.93) 0%, rgba(25,106,213,0.82) 55%, rgba(25,106,213,0.55) 100%), url('/img/atelier.jpg');">
  <div class="mx-auto max-w-[1180px] px-6 py-16 text-white md:py-20">
    <div class="max-w-xl">
      <span class="eyebrow text-accent">À domicile ou au travail</span>
      <h2 class="mt-3 text-3xl font-extrabold text-white md:text-4xl">On se déplace {lieu}</h2>
      <p class="mt-4 text-white/90">{sousTitre}</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <div class="rounded-xl bg-white/15 px-5 py-3"><p class="font-display text-2xl font-extrabold text-accent">−15 %</p><p class="text-xs text-white/85">de consommation*</p></div>
        <div class="rounded-xl bg-white/15 px-5 py-3"><p class="font-display text-2xl font-extrabold text-accent">−70 %</p><p class="text-xs text-white/85">de pollution*</p></div>
        <div class="rounded-xl bg-white/15 px-5 py-3"><p class="font-display text-2xl font-extrabold text-accent">0</p><p class="text-xs text-white/85">démontage moteur</p></div>
      </div>
      <p class="mt-3 text-xs text-white/60">*Réductions annoncées, constatées selon l'état d'encrassement du véhicule.</p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/prise-de-rendez-vous" class="rounded-full bg-accent px-7 py-3.5 font-display font-extrabold text-ink shadow-lg transition-transform hover:-translate-y-0.5">Réserver une intervention</a>
        <a href={waLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border-2 border-white/40 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/10">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={WA_PATH} /></svg>
          Devis WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
